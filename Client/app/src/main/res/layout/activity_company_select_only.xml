<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <Button
        android:id="@+id/btnBackCompany"
        style="@style/Btn.Secondary"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text="@string/back"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <TextView
        style="@style/App.Title.Large"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/select_company_title"
        android:layout_marginBottom="@dimen/spacing_md"/>

    <TextView
        android:id="@+id/tvCompanyStatus"
        style="@style/App.Status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/select_company"
        android:layout_marginBottom="@dimen/spacing_md"/>

    <Button
        android:id="@+id/btnLoadCompanies"
        style="@style/Btn.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/load_companies"
        android:layout_marginBottom="@dimen/spacing_md" />

    <ListView
        android:id="@+id/listViewCompanies"
        style="@style/App.ListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:cacheColorHint="@android:color/transparent" />

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="220dp"
        android:layout_height="140dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_lg"
        android:adjustViewBounds="true"
        android:src="@drawable/delivery_logo"
        android:contentDescription="@string/app_name" />

</LinearLayout>
