<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_soft"
    android:orientation="vertical"
    android:padding="24dp">

    <Button
        android:id="@+id/btnBackCompany"
        style="@style/Btn.Primary"
        android:layout_width="120dp"
        android:text="@string/back"
        android:layout_marginBottom="14dp" />

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="220dp"
        android:layout_height="120dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="10dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/app_name"
        android:src="@drawable/delivery_logo" />

    <TextView
        android:id="@+id/tvCompanyTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/company_login_title"
        android:textColor="@color/text_main"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_light"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvCompanyStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/company_login_hint"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etCompanyName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/company_username_hint"
        android:inputType="text"
        android:layout_marginBottom="10dp" />

    <EditText
        android:id="@+id/etCompanyId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/company_password_hint"
        android:inputType="textPassword"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnLoginCompany"
        style="@style/Btn.Success"
        android:layout_width="match_parent"
        android:text="@string/login"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnLoadCompanies"
        style="@style/Btn.Primary"
        android:layout_width="match_parent"
        android:text="@string/load_companies"
        android:layout_marginBottom="10dp" />

    <ListView
        android:id="@+id/listViewCompanies"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>