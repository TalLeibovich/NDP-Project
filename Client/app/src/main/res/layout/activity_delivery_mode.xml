<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_soft"
    android:orientation="vertical"
    android:padding="24dp">

    <Button
        android:id="@+id/btnBackDeliveryMode"
        style="@style/Btn.Primary"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text="@string/back"
        android:layout_marginBottom="12dp"/>

    <ImageView
        android:id="@+id/imgLogoDelivery"
        android:layout_width="200dp"
        android:layout_height="110dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="10dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/app_name"
        android:src="@drawable/delivery_logo" />

    <TextView
        android:id="@+id/tvDeliveryHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Delivery Mode"
        android:textColor="@color/text_main"
        android:textStyle="bold"
        android:textSize="20sp"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnNextStop"
        style="@style/Btn.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/next_stop"
        android:layout_marginBottom="12dp"/>

    <!-- NEW: Complete route (release run on server) -->
    <Button
        android:id="@+id/btnCompleteRoute"
        style="@style/Btn.Danger"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/complete_route_release"
        android:layout_marginBottom="12dp"/>

    <ListView
        android:id="@+id/listViewDeliveryStops"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>