<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/background_soft">

    <Button
        android:id="@+id/btnBackOptimizeResult"
        style="@style/Btn.Primary"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text="@string/back"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvRouteReadyTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/route_ready"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_main"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tvOptimizeSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_optimize_result"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnAssignToCourier"
        style="@style/Btn.Success"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/assign_to_courier"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnStartDeliveryMode"
        style="@style/Btn.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/start_delivery_mode"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnOpenRouteMap"
        style="@style/Btn.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/open_route_map"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnResetLocalStatuses"
        style="@style/Btn.Danger"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/reset_local_statuses"
        android:layout_marginBottom="12dp" />

    <ListView
        android:id="@+id/listViewRouteStops"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>