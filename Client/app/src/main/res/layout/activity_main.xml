<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/imgLogoMain"
            android:layout_width="220dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/spacing_md"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:src="@drawable/delivery_logo" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Manager Dashboard"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <TextView
            android:id="@+id/tvMainStatus"
            style="@style/App.Status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl"
            android:text="@string/stage_5_ready" />

        <Button
            android:id="@+id/btnManagePackages"
            style="@style/Btn.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/manage_packages"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <Button
            android:id="@+id/btnContinueLastRoute"
            style="@style/Btn.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/view_courier_route"
            android:layout_marginBottom="@dimen/spacing_md"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnChangeCourier"
            style="@style/Btn.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/change_courier"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <Button
            android:id="@+id/btnCompanyDefaultAddress"
            style="@style/Btn.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Company Default Address"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <Button
            android:id="@+id/btnCourierDefaults"
            style="@style/Btn.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Courier Optimization Defaults"
            android:layout_marginBottom="@dimen/spacing_xl"/>

        <Button
            android:id="@+id/btnRunOptimization"
            style="@style/Btn.Success"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/run_optimization"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <Button
            android:id="@+id/btnReleaseActiveRun"
            style="@style/Btn.Danger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Release Active Run (Company)"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <Button
            android:id="@+id/btnLogout"
            style="@style/Btn.Danger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/logout"/>
    </LinearLayout>

</ScrollView>
