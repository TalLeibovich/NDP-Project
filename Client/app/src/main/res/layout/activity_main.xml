<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_soft">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/imgLogoMain"
            android:layout_width="220dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="10dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:src="@drawable/delivery_logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manager Dashboard"
            android:textColor="@color/text_main"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvMainStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="18dp"
            android:text="@string/stage_5_ready" />

        <Button
            android:id="@+id/btnManagePackages"
            style="@style/Btn.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/manage_packages"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnContinueLastRoute"
            style="@style/Btn.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/view_courier_route"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnChangeCourier"
            style="@style/Btn.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/change_courier"
            android:layout_marginBottom="18dp"/>

        <Button
            android:id="@+id/btnRunOptimization"
            style="@style/Btn.Success"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/run_optimization"
            android:layout_marginBottom="12dp"/>

        <!-- ✅ NEW: Release Active Run (company-level) -->
        <Button
            android:id="@+id/btnReleaseActiveRun"
            style="@style/Btn.Danger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Release Active Run (Company)"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnLogout"
            style="@style/Btn.Danger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/logout"/>
    </LinearLayout>

</ScrollView>