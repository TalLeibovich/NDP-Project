<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="260dp"
        android:layout_height="160dp"
        android:layout_marginBottom="@dimen/spacing_md"
        android:adjustViewBounds="true"
        android:contentDescription="@string/app_name"
        android:src="@drawable/delivery_logo" />

    <TextView
        android:id="@+id/tvSplashTitle"
        style="@style/App.Title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:text="Smart Delivery Planner" />

    <TextView
        android:id="@+id/tvSplashStatus"
        style="@style/App.Subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_xl"
        android:text="Checking server..."
        android:textSize="14sp" />

    <ProgressBar
        android:id="@+id/progressSplash"
        style="@style/App.ProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_xl" />

    <Button
        android:id="@+id/btnRetry"
        style="@style/Btn.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:text="Retry"
        android:visibility="gone" />

</LinearLayout>
