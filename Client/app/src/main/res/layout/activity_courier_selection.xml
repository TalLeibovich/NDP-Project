<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <Button
        android:id="@+id/btnBackCourier"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text="@string/back"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvCourierTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/select_courier"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvSelectedCompany"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_company_selected"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvCourierStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/loading_couriers"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnLoadCouriers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/load_couriers"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etCourierId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/courier_id_hint"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etCourierName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/courier_name_hint"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnAddCourier"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/add_courier"
        android:layout_marginBottom="16dp" />

    <ListView
        android:id="@+id/listViewCouriers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>