<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/card_surface"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg"
    android:layout_marginBottom="@dimen/spacing_md">

    <TextView
        android:id="@+id/tvStopTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Stop"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginBottom="@dimen/spacing_sm" />

    <TextView
        android:id="@+id/tvStopDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="details"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="@dimen/spacing_sm" />

    <TextView
        android:id="@+id/tvStopStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Status: NOT_STARTED"
        android:textColor="@color/accent_primary"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/spacing_md" />

    <View
        style="@style/App.Divider"
        android:layout_marginBottom="@dimen/spacing_md" />

    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnDelivered"
            style="@style/Btn.Success"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/delivered" />

        <View
            android:layout_width="@dimen/spacing_md"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/btnFailed"
            style="@style/Btn.Danger"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/failed" />

    </LinearLayout>

</LinearLayout>
