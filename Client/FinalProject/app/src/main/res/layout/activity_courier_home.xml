<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/imgLogoCourier"
            android:layout_width="220dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/spacing_md"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:src="@drawable/delivery_logo" />

        <TextView
            style="@style/App.Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/courier_dashboard"
            android:textSize="22sp"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <TextView
            android:id="@+id/tvCourierStatus"
            style="@style/App.Status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl"
            android:text="-" />

        <Button
            android:id="@+id/btnCourierRunOptimize"
            style="@style/Btn.Success"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/run_optimization"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <Button
            android:id="@+id/btnCourierStartOrContinue"
            style="@style/Btn.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/start_or_continue_delivery"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <Button
            android:id="@+id/btnCourierOpenMap"
            style="@style/Btn.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/open_route_map"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <Button
            android:id="@+id/btnCourierCompleteRoute"
            style="@style/Btn.Danger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/complete_route_release"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <Button
            android:id="@+id/btnCourierOptimizationDefaults"
            style="@style/Btn.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Optimization Defaults"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <Button
            android:id="@+id/btnCourierLogout"
            style="@style/Btn.Danger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/logout" />

    </LinearLayout>
</ScrollView>
