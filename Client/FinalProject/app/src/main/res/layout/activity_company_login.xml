<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <TextView
        style="@style/App.Title.Large"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/company_login_title"
        android:layout_marginBottom="@dimen/spacing_lg"/>

    <TextView
        android:id="@+id/tvLoginStatus"
        style="@style/App.Subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/company_login_hint"
        android:layout_marginBottom="@dimen/spacing_lg"/>

    <EditText
        android:id="@+id/etCompanyName"
        style="@style/App.Input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/company_username_hint"
        android:inputType="text"
        android:layout_marginBottom="@dimen/spacing_md"/>

    <EditText
        android:id="@+id/etCompanyId"
        style="@style/App.Input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/company_password_hint"
        android:inputType="textPassword"
        android:layout_marginBottom="@dimen/spacing_lg"/>

    <Button
        android:id="@+id/btnLoadCompaniesForLogin"
        style="@style/Btn.Secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/load_companies"
        android:layout_marginBottom="@dimen/spacing_md"/>

    <Button
        android:id="@+id/btnLoginCompany"
        style="@style/Btn.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/login"
        android:layout_marginBottom="@dimen/spacing_lg"/>

    <TextView
        android:id="@+id/tvCompaniesPreview"
        style="@style/App.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"/>

</LinearLayout>
